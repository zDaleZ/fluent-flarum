{
    "name": "dalez/fluent-flarum",
    "description": "A Flarum theme comply with Fluent Design System.",
    "keywords": [
        "flarum"
    ],
    "type": "flarum-extension",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/zDaleZ/fluent-flarum/issues",
        "source": "https://github.com/zDaleZ/fluent-flarum",
        "forum": "https://discuss.flarum.org/d/21492"
    },
    "require": {
        "flarum/core": "^1.8"
    },
    "extra": {
        "flarum-extension": {
            "title": "Fluent",
            "category": "theme",
            "icon": {
                "name": "fab fa-microsoft",
                "backgroundColor": "#0078d4",
                "color": "#fff"
            }
        }
    }
